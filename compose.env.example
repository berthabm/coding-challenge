#
# Opcional — usado solo para interpolación en `docker compose` (puertos, timeouts).
# Copia a `.env` en la raíz del monorepo para personalizar.
#
# Ejemplo:
#   cp compose.env.example .env
#

API_GO_PORT=8080
API_NODE_PORT=3001
FRONTEND_PORT=5173
NODE_ENV=production
LOG_LEVEL=info
API2_TIMEOUT_SECONDS=10

# JWT authentication (api-go)
AUTH_USERNAME=admin
AUTH_PASSWORD=admin123
# ⚠️  Cambia JWT_SECRET en producción por un valor seguro de al menos 32 caracteres
JWT_SECRET=change-me-in-production

# CORS — orígenes permitidos para llamadas desde el browser (separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# URL base que el frontend usa para llamar a api-go (build-time arg de Vite)
VITE_API_BASE_URL=http://localhost:8080
